<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.GalleryController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search galleries..." HBox.hgrow="ALWAYS" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
        <Button text="Add" onAction="#handleAddGallery" />
        <Button text="Edit" onAction="#handleEditGallery" />
        <Button text="Delete" onAction="#handleDeleteGallery" />
    </HBox>
    <TableView fx:id="galleryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200" />
            <TableColumn fx:id="addressColumn" text="Address" prefWidth="220" />
            <TableColumn fx:id="ownerNameColumn" text="Owner" prefWidth="160" />
            <TableColumn fx:id="openingHoursColumn" text="Opening Hours" prefWidth="160" />
            <TableColumn fx:id="contactPhoneColumn" text="Phone" prefWidth="140" />
            <TableColumn fx:id="ratingColumn" text="Rating" prefWidth="80" />
            <TableColumn fx:id="websiteColumn" text="Website" prefWidth="220" />
        </columns>
    </TableView>
</VBox>
