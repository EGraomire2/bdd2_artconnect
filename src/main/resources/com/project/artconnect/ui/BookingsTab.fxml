<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.BookingController">
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search bookings" HBox.hgrow="ALWAYS" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>

    <TableView fx:id="bookingTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="70" />
            <TableColumn fx:id="workshopColumn" text="Workshop" prefWidth="240" />
            <TableColumn fx:id="memberColumn" text="Member" prefWidth="220" />
            <TableColumn fx:id="dateColumn" text="Booking Date" prefWidth="180" />
            <TableColumn fx:id="paymentStatusColumn" text="Payment Status" prefWidth="150" />
        </columns>
    </TableView>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Add" onAction="#handleAddBooking" />
        <Button text="Edit" onAction="#handleEditBooking" />
        <Button text="Delete" onAction="#handleDeleteBooking" />
    </HBox>
</VBox>