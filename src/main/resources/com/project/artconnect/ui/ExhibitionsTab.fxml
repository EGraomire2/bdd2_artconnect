<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ExhibitionController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search exhibitions..." HBox.hgrow="ALWAYS" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
        <Button text="Add" onAction="#handleAddExhibition" />
        <Button text="Edit" onAction="#handleEditExhibition" />
        <Button text="Delete" onAction="#handleDeleteExhibition" />
    </HBox>
    <TableView fx:id="exhibitionTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="galleryColumn" text="Gallery" prefWidth="150" />
            <TableColumn fx:id="dateColumn" text="Start Date" prefWidth="120" />
            <TableColumn fx:id="themeColumn" text="Theme" prefWidth="180" />
        </columns>
    </TableView>
</VBox>
